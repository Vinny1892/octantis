# OTLP Receiver
OTLP_GRPC_PORT=4317
OTLP_HTTP_PORT=4318
OTLP_GRPC_ENABLED=true
OTLP_HTTP_ENABLED=true
OTLP_QUEUE_MAX_SIZE=1000

# LLM
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-6
ANTHROPIC_API_KEY=sk-ant-...
# OPENROUTER_API_KEY=sk-or-...

# Prometheus
PROMETHEUS_URL=http://prometheus:9090

# Kubernetes
K8S_IN_CLUSTER=false
# K8S_KUBECONFIG=~/.kube/config  # used when K8S_IN_CLUSTER=false

# Slack
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
# SLACK_BOT_TOKEN=xoxb-...  # optional, for richer API calls
SLACK_CHANNEL=#infra-alerts

# Discord
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Agent behavior
MIN_SEVERITY_TO_NOTIFY=MODERATE  # CRITICAL, MODERATE, LOW, NOT_A_PROBLEM
LOG_LEVEL=INFO

# Pipeline - Pre-filter thresholds (events below ALL thresholds are dropped before LLM)
PIPELINE_CPU_THRESHOLD=75.0
PIPELINE_MEMORY_THRESHOLD=80.0
PIPELINE_ERROR_RATE_THRESHOLD=0.01
# Comma-separated regex patterns to always drop (e.g. known batch jobs, scrapers)
PIPELINE_BENIGN_PATTERNS=nightly-batch,prometheus-scrape
# Comma-separated event types to allow through (empty = allow all)
PIPELINE_ALLOWED_EVENT_TYPES=

# Pipeline - Batcher (merge events from same workload before calling LLM)
PIPELINE_BATCH_WINDOW_SECONDS=30.0
PIPELINE_BATCH_MAX_SIZE=20

# Pipeline - Sampler (suppress repeated identical issues within cooldown)
PIPELINE_SAMPLER_COOLDOWN_SECONDS=300
PIPELINE_SAMPLER_MAX_ENTRIES=1000
