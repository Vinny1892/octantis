# OTLP Receiver
OTLP_GRPC_PORT=4317
OTLP_HTTP_PORT=4318
OTLP_GRPC_ENABLED=true
OTLP_HTTP_ENABLED=true
OTLP_QUEUE_MAX_SIZE=1000

# LLM
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-6
ANTHROPIC_API_KEY=sk-ant-...
# OPENROUTER_API_KEY=sk-or-...

# LLM Investigation Model (optional)
# The model used for the investigation node (MCP tool calling, ReAct loop).
# Defaults to LLM_MODEL if not set. Operators can set a more capable model
# (e.g., claude-opus-4-6) for better investigation quality at higher cost.
# LLM_INVESTIGATION_MODEL=claude-sonnet-4-6

# Grafana MCP (required for autonomous investigation)
GRAFANA_MCP_URL=http://mcp-grafana:8080/sse
GRAFANA_MCP_API_KEY=glsa_...

# K8s MCP (optional, recommended for Kubernetes context enrichment)
# When configured, the LLM can query pod status, events, deployments, etc.
# K8S_MCP_URL=http://mcp-k8s:8080/sse

# Investigation settings
INVESTIGATION_MAX_QUERIES=10           # Max MCP queries per investigation
INVESTIGATION_TIMEOUT_SECONDS=60       # Total investigation timeout
INVESTIGATION_QUERY_TIMEOUT_SECONDS=10 # Per-query MCP timeout

# Prometheus metrics
METRICS_PORT=9090
METRICS_ENABLED=true

# Slack
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
# SLACK_BOT_TOKEN=xoxb-...  # optional, for richer API calls
SLACK_CHANNEL=#infra-alerts

# Discord
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Agent behavior
MIN_SEVERITY_TO_NOTIFY=MODERATE  # CRITICAL, MODERATE, LOW, NOT_A_PROBLEM
LOG_LEVEL=INFO

# Pipeline - Trigger filter thresholds (events below ALL thresholds are dropped)
PIPELINE_CPU_THRESHOLD=75.0
PIPELINE_MEMORY_THRESHOLD=80.0
PIPELINE_ERROR_RATE_THRESHOLD=0.01
# Comma-separated regex patterns to always drop (e.g. known batch jobs, scrapers)
PIPELINE_BENIGN_PATTERNS=nightly-batch,prometheus-scrape

# Pipeline - Fingerprint cooldown (suppress repeated identical issues)
PIPELINE_COOLDOWN_SECONDS=300
PIPELINE_COOLDOWN_MAX_ENTRIES=1000
